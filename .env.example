# ── LLM ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Google (file paths, no credentials here) ─────────────────────
# Place credentials.json in env/ — downloaded from Google Cloud Console
# token.json is auto-created by: python scripts/get_oauth_token.py
# GOOGLE_CREDENTIALS_FILE=env/credentials.json   # (default, no need to set)
# GOOGLE_TOKEN_FILE=env/token.json               # (default, no need to set)

# ── Optional tuning ──────────────────────────────────────────────
EMAIL_LOOKBACK_MINUTES=30
APPROVAL_TIMEOUT_SECONDS=300
